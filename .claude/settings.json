{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit",
      "Read(/tmp/**)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(sed:*)",
      "Bash(mkdir:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "WebSearch"
    ]
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "language": "japanese",
  "teammateMode": "tmux"
}
